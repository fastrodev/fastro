{
  "lock": false,
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "nodeModulesDir": "auto",
  "tasks": {
    "start": "FASTRO_ENV=development deno run -A build/watch.ts & FASTRO_ENV=development deno run -A --unstable-kv --watch main.ts 3000",
    "gen-manifest": "deno run -A ./scripts/generate_manifest.ts",
    "build": "deno run -A build/mod.ts",
    "bench": "bash ./scripts/run_bench.sh",
    "test": "deno test -A",
    "lint": "deno lint",
    "cov": "deno task lint && deno test -A --coverage=coverage && deno coverage --lcov coverage > coverage.lcov || true"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "jsxImportSourceTypes": "@types/react",
    "lib": [
      "deno.ns",
      "deno.unstable",
      "dom",
      "dom.iterable",
      "dom.asynciterable"
    ]
  },
  "imports": {
    "@deno/loader": "jsr:@deno/loader@^0.3.13",
    "react/jsx-runtime": "npm:react@^19.2.4/jsx-runtime",
    "@types/react": "npm:@types/react@^19.0.8",
    "@types/react-dom": "npm:@types/react-dom@^19.0.3",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "react": "npm:react@^19.2.4",
    "react-dom": "npm:react-dom@^19.2.4",
    "@std/path": "jsr:@std/path@^1.1.4",
    "tailwindcss": "npm:tailwindcss@^4.2.1",
    "esbuild": "npm:esbuild@^0.25.0"
  }
}
